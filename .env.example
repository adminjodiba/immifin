# Copy to .env.local and fill in values only when overriding defaults in lib/visaBulletinConfig.ts.
# .env.local is gitignored — never commit real credentials.

# Optional visa bulletin CSV overrides (defaults are committed in lib/visaBulletinConfig.ts)
# VISA_BULLETIN_PUBLISH_BASE=
# VISA_BULLETIN_GID_FINAL_ACTION_DATES=
# VISA_BULLETIN_GID_DATES_FOR_FILING=
# VISA_BULLETIN_GID_PREVIOUS_FINAL_ACTION_DATES=
# VISA_BULLETIN_GID_PREVIOUS_DATES_FOR_FILING=
# VISA_BULLETIN_GID_HISTORY=

# Google Sheets API (admin archive — app/api/admin/archive-visa-bulletin)
# GOOGLE_SHEET_ID=
# GOOGLE_CLIENT_EMAIL=
# GOOGLE_PRIVATE_KEY=
# Optional history tab name (default: VisaBulletinHistory)
# VISA_BULLETIN_HISTORY_SHEET=VisaBulletinHistory
