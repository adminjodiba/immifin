# Copy to .env.local and fill in your values.
# .env.local is gitignored — never commit real credentials.

# Optional: published CSV URL for FinalActionDates (legacy single-sheet loader in lib/visaBulletinData.ts)
# VISA_BULLETIN_CSV_URL=

# Multi-sheet loaders (lib/visaBulletinSheets.ts)
# Option A — full URL per sheet:
# VISA_BULLETIN_URL_FINAL_ACTION_DATES=
# VISA_BULLETIN_URL_DATES_FOR_FILING=
# VISA_BULLETIN_URL_PREVIOUS_FINAL_ACTION_DATES=
# VISA_BULLETIN_URL_PREVIOUS_DATES_FOR_FILING=

# Option B — publish base + tab gid per sheet:
# VISA_BULLETIN_PUBLISH_BASE=https://docs.google.com/spreadsheets/d/e/YOUR_PUBLISH_ID/pub
# VISA_BULLETIN_GID_FINAL_ACTION_DATES=
# VISA_BULLETIN_GID_DATES_FOR_FILING=
# VISA_BULLETIN_GID_PREVIOUS_FINAL_ACTION_DATES=
# VISA_BULLETIN_GID_PREVIOUS_DATES_FOR_FILING=
