# Copy to .env.local and fill in values only when overriding defaults in lib/visaBulletinConfig.ts
# and lib/visaStampingConfig.ts.
# .env.local is gitignored — never commit real credentials.

# Google Sheets workbook (Immifin GC Dates) — used by admin API and stamping config
# GOOGLE_SPREADSHEET_ID=
# GOOGLE_SHEET_ID=

# Optional stamping wait-time tab gids (defaults in lib/visaStampingConfig.ts)
# STAMPING_WAIT_TIME_GID_CURRENT=
# STAMPING_WAIT_TIME_GID_HISTORY=
# STAMPING_WAIT_TIME_GID_CITY_METADATA=

# Optional visa bulletin CSV overrides (defaults are committed in lib/visaBulletinConfig.ts)
# VISA_BULLETIN_PUBLISH_BASE=
# VISA_BULLETIN_GID_FINAL_ACTION_DATES=
# VISA_BULLETIN_GID_DATES_FOR_FILING=
# VISA_BULLETIN_GID_PREVIOUS_FINAL_ACTION_DATES=
# VISA_BULLETIN_GID_PREVIOUS_DATES_FOR_FILING=
# VISA_BULLETIN_GID_HISTORY=

# Google Sheets API (admin archive — app/api/admin/archive-visa-bulletin)
# GOOGLE_SHEET_ID=
# GOOGLE_CLIENT_EMAIL=
# GOOGLE_PRIVATE_KEY=
# Optional history tab name (default: VisaBulletinHistory)
# VISA_BULLETIN_HISTORY_SHEET=VisaBulletinHistory

# Clerk (authentication)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
# CLERK_WEBHOOK_SECRET=
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
#
# Sign-up field requirements (first/last name required, profile image optional):
#   npm run clerk:config:signup
# See docs/auth/MILESTONE1_STEP1.md

# Supabase (application data — server only except URL)
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Development Subscription Mode — local development only (server-side flag).
# Production always forces this feature off in application code.
# true  — local Free / Pro / Power switching without payment (feature development).
# false — trusted database subscription tier only (Stripe Sandbox end-to-end testing).
# Restart the dev server after changing this value.
# IMMIFIN_ENABLE_DEVELOPMENT_SUBSCRIPTION_MODE=false

# Public site URL used for email deep links (dashboard CTA). Optional in local dev.
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Notification Platform / Resend (S6-EMAIL-001A) — server only, never NEXT_PUBLIC_
# See docs/NOTIFICATION_DESIGN.md · Email Identity Strategy
# ---------------------------------------------------------------------------
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=updates@notifications.immifin.com
# RESEND_FROM_NAME=IMMIFIN
# RESEND_REPLY_TO=support@immifin.com
# RESEND_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Stripe (S7-STR-001) — server secrets never NEXT_PUBLIC_ except publishable key
# See docs/STRIPE_OPERATIONS.md · docs/BILLING_ARCHITECTURE.md
# ---------------------------------------------------------------------------
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PRO_MONTHLY=
# STRIPE_PRICE_PRO_ANNUAL=
# STRIPE_PRICE_POWER_MONTHLY=
# STRIPE_PRICE_POWER_ANNUAL=
